<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.or.gtcs.menuurl.mapper.MenuUrlMapper">


	<select id="existsByUrl" resultType="kr.or.gtcs.dto.MenuUrlDTO">
		SELECT
		MENU_NAME,
		MENU_URL,
		ROLE_CODE
		FROM MENU_URL
		WHERE MENU_URL = #{menuUrl}
	</select>

</mapper>